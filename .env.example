# Copy to .env and fill in real values. .env is gitignored.

# OpenAI — used for the classifier (gpt-4.1-nano), generator (gpt-4.1),
# and the text-embedding-3-small embeddings used by retrieval.
OPENAI_API_KEY=sk-...

# Anthropic — used for the guardrail (claude-sonnet-4-6).
# Routed through LiteLLM, same as OpenAI.
ANTHROPIC_API_KEY=sk-ant-...
